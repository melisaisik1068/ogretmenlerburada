DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — tarayıcıdan gelen frontend kök adresleri (virgülle)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF — üretimde Django admin vb. için https kökleri (virgülle)
CSRF_TRUSTED_ORIGINS=

# Railway / bazı Paas: PostgreSQL URL’i tek satırda (varsa SQLite yerine kullanılır)
# DATABASE_URL=postgres://...

# Yerel Postgres (DATABASE_URL kullanılmıyorsa)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ogretmenlerburada
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
