DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — tarayıcıdan gelen frontend kök adresleri (virgülle)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF — üretimde Django admin vb. için https kökleri (virgülle)
CSRF_TRUSTED_ORIGINS=

# Üretimde /media genelde kapalı
DJANGO_SERVE_MEDIA_PUBLIC=0

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_SUBSCRIPTIONS=
STRIPE_WEBHOOK_SECRET_SHOP=

# Ödeme sonrası yönlendirme (Vercel kökü)
FRONTEND_URL=http://localhost:3000

# İyzico callback tam URL üretmek için API public kökü (sonunda / yok)
# Örn. https://xxxx.up.railway.app
API_PUBLIC_URL=

IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=sandbox-api.iyzipay.com
IYZICO_PLACEHOLDER_IDENTITY=11111111111
IYZICO_PLACEHOLDER_GSM=+905551112233

# Pazaryeri satıcı komisyonu (%)
MARKETPLACE_COMMISSION_PERCENT=15

# E-posta (üretimde SMTP)
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_USE_TLS=1
# DJANGO_EMAIL_HOST_USER=
# DJANGO_EMAIL_HOST_PASSWORD=

# Railway / bazı Paas: PostgreSQL URL’i tek satırda (varsa SQLite yerine kullanılır)
# DATABASE_URL=postgres://...

# Yerel Postgres (DATABASE_URL kullanılmıyorsa)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ogretmenlerburada
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
